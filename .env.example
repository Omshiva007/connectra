# Connectra Environment Configuration
# Copy this file to .env and fill in the values.

# ── Paths ────────────────────────────────────────────────────────────────────
# Override the runtime data directory (default: ~/.connectra)
# CONNECTRA_DATA_DIR=/path/to/your/data/directory

# ── Security ─────────────────────────────────────────────────────────────────
# 32-byte URL-safe base64 key used to encrypt stored passwords.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If omitted a key file is auto-created at <CONNECTRA_DATA_DIR>/.secret_key.
# CONNECTRA_SECRET_KEY=your-base64-url-safe-32-byte-key-here

# ── Backend ───────────────────────────────────────────────────────────────────
# URL of the Connectra FastAPI backend (default: http://localhost:8000)
# CONNECTRA_BACKEND_URL=http://localhost:8000
